body{
  margin:0;
  font-family:Arial,sans-serif;
  background:#000;
  color:#fff;
  display:flex;
  justify-content:center;
  align-items:center;
  height:100vh;
}

.game{
  text-align:center;
}

h1{
  color:#00d4ff;
}

button{
  padding:10px 20px;
  margin:10px;
  border:none;
  background:#ff5722;
  color:#fff;
  cursor:pointer;
  border-radius:5px;
}

button:hover{
  background:#e64a19;
}

canvas{
  display:block;
  margin:10px auto;
  border:2px solid #fff;
  background:#111;
}
